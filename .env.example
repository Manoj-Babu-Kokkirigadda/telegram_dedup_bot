# Telegram bot token from @BotFather (REQUIRED)
BOT_TOKEN=

# Async SQLAlchemy URL. Default: local SQLite file.
# PostgreSQL example: postgresql+asyncpg://user:pass@host:5432/dedup
DATABASE_URL=sqlite+aiosqlite:///./dedup.db

# Default Hamming-distance threshold for perceptual image similarity (0-20).
# Lower = stricter. Default: 10
PHASH_THRESHOLD=10

# Perceptual hash threshold for video thumbnail pHash matching (0-20).
# Lower = stricter. Default: 8
VIDEO_PHASH_THRESHOLD=8

# Send a notification to the chat when a duplicate is deleted.
# The notification auto-deletes after 10 seconds. Default: true
NOTIFY_ON_DELETE=true

# Temp directory used to download incoming media before hashing.
DOWNLOAD_DIR=./downloads

# Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Maximum media messages per chat per 60 seconds before dedup pauses.
# Default: 50
MAX_MEDIA_PER_MINUTE=50

# How many seconds to pause dedup when the chat rate limit is hit.
# Default: 30
RATE_LIMIT_PAUSE_SECONDS=30

# ---------------------------------------------------------------------------
# PostgreSQL (only needed when using the postgres docker-compose profile)
# ---------------------------------------------------------------------------
# PG_USER=dedup
# PG_PASSWORD=dedup_secret
# PG_DATABASE=dedup
